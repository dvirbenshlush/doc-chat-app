{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: Debug Server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--port", "8000"],
      "cwd": "${workspaceFolder}/server",
      "envFile": "${workspaceFolder}/server/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/server"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
